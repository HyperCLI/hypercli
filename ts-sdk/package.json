{
  "name": "@hypercli.com/sdk",
  "version": "2026.4.13-3",
  "description": "TypeScript SDK for HyperCLI API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    },
    "./agent": {
      "import": "./dist/agent.js",
      "types": "./dist/agent.d.ts"
    },
    "./agents": {
      "import": "./dist/agents.js",
      "types": "./dist/agents.d.ts"
    },
    "./gateway": {
      "import": "./dist/gateway.js",
      "types": "./dist/gateway.d.ts"
    },
    "./openclaw/gateway": {
      "import": "./dist/openclaw/gateway.js",
      "types": "./dist/openclaw/gateway.d.ts"
    },
    "./keys": {
      "import": "./dist/keys.js",
      "types": "./dist/keys.d.ts"
    },
    "./http": {
      "import": "./dist/http.js",
      "types": "./dist/http.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run tests/config.test.ts tests/client.test.ts tests/jobs.test.ts tests/keys.test.ts tests/models.test.ts tests/exec-shell-dryrun.test.ts tests/gateway.test.ts",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest"
  },
  "keywords": [
    "hypercli",
    "gpu",
    "cloud",
    "compute",
    "inference"
  ],
  "author": "Compute3 AI",
  "license": "MIT",
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
