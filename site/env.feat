# Feat environment — production backend with feat frontend hostnames
# Netlify feat site build command: cp env.feat .env.local && npm run build

# Site URLs
NEXT_PUBLIC_MAIN_SITE_URL=https://feat.hypercli.com
NEXT_PUBLIC_CONSOLE_URL=https://console.feat.hypercli.com
NEXT_PUBLIC_AGENTS_URL=https://agents.feat.hypercli.com

# Cookie Configuration
NEXT_PUBLIC_COOKIE_DOMAIN=.hypercli.com
NEXT_PUBLIC_HYPERCLAW_COOKIE_DOMAIN=.hypercli.com
NEXT_PUBLIC_COOKIE_VALIDITY=15

# Auth
NEXT_PUBLIC_PRIVY_APP_ID=cml5njpn701s2ky0cjd0y1vzq
NEXT_PUBLIC_AUTH_DEBUG=false

# API URLs — auth goes to Orchestra, app data goes to HyperClaw
NEXT_PUBLIC_API_BASE_URL=https://api.hypercli.com
NEXT_PUBLIC_AUTH_BACKEND=https://api.hypercli.com/api
NEXT_PUBLIC_INSTANCES_API_URL=https://api.hypercli.com/instances
NEXT_PUBLIC_LLM_API_URL=https://api.hypercli.com/v1
NEXT_PUBLIC_BOT_API_URL=https://api.hypercli.com/agent/api
NEXT_PUBLIC_WS_URL=wss://api.hypercli.com
NEXT_PUBLIC_AGENTS_WS_URL=wss://api.agents.hypercli.com/ws
NEXT_PUBLIC_SLACK_RELAY_BASE_URL=https://api.agents.hypercli.com
NEXT_PUBLIC_SLACK_APP_HANDLE=hyper
NEXT_PUBLIC_OPENCLAW_IMAGE=ghcr.io/hypercli/hypercli-openclaw:pro-latest
NEXT_PUBLIC_OPENCLAW_PRO_IMAGE=ghcr.io/hypercli/hypercli-openclaw:pro-latest

AGENTS_WS_URL=$NEXT_PUBLIC_AGENTS_WS_URL

