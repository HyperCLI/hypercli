{
  "name": "@hypercli/claw",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "sh -lc 'next dev --port ${PORT:-4003}'",
    "dev:mock": "cp .env.mock .env.local && npm run dev",
    "dev:real": "cp .env.feat .env.local && npm run dev",
    "switch:mock": "cp .env.mock .env.local && echo '✅ Switched to MOCK server'",
    "switch:feat": "cp .env.feat .env.local && echo '✅ Switched to REAL API'",
    "build": "next build",
    "start": "sh -lc 'next start --port ${PORT:-4003}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:api-boundary": "node scripts/check-api-boundary.mjs",
    "lint": "npm run lint:api-boundary && eslint",
    "clean": "rm -rf .next",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@hypercli.com/sdk": "2026.5.5",
    "@hypercli/shared-ui": "*",
    "@privy-io/react-auth": "^3.13.1",
    "@tanstack/react-query": "^5.90.10",
    "@x402/axios": "^2.0.0",
    "@x402/evm": "^2.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "axios": "^1.7.0",
    "framer-motion": "^11.18.0",
    "lucide-react": "*",
    "next": "*",
    "react": "*",
    "react-dom": "*",
    "react-syntax-highlighter": "^15.6.1",
    "viem": "^2.39.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.1",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/postcss": "*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "*",
    "eslint-config-next": "*",
    "eslint-plugin-storybook": "^10.3.5",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.3.0",
    "null-loader": "^4.0.1",
    "storybook": "^10.3.5",
    "tailwindcss": "*",
    "typescript": "5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
