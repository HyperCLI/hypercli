{
  "name": "hypercli-mock-server",
  "version": "1.0.0",
  "description": "Mock Agents API for local development",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "chat": "node chat-server.js",
    "chat:dev": "nodemon chat-server.js",
    "start:all": "concurrently \"npm start\" \"npm run chat\" --names \"agents\" \"chat\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "@faker-js/faker": "^8.3.1",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^9.2.1"
  }
}
