{
    "name": "hypercli-monorepo",
    "version": "2026.4.7",
    "private": true,
    "packageManager": "npm@10.0.0",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules",
    "cors-proxy": "node cors-anywhere.js",
    "clear-cache": "node scripts/clear-cache.js",
    "clear-cache:bat": "scripts\\clear-cache.bat",
    "dev:apps": "turbo run dev",
    "sdk:use-checkout": "rm -rf node_modules/@hypercli.com/sdk apps/claw/node_modules/@hypercli.com/sdk apps/console/node_modules/@hypercli.com/sdk packages/shared-ui/node_modules/@hypercli.com/sdk && npm link ../ts-sdk --workspace @hypercli/claw --workspace @hypercli/console --workspace @hypercli/shared-ui",
    "sdk:use-local": "npm run sdk:use-checkout",
    "sdk:use-published": "rm -rf node_modules/@hypercli.com/sdk apps/claw/node_modules/@hypercli.com/sdk apps/console/node_modules/@hypercli.com/sdk packages/shared-ui/node_modules/@hypercli.com/sdk && npm install --save-exact @hypercli.com/sdk@2026.4.7-2 --workspace @hypercli/claw --workspace @hypercli/console --workspace @hypercli/shared-ui"
  },
    "dependencies": {
        "@tailwindcss/postcss": "^4",
        "lucide-react": "^0.487.0",
        "next": "^16.0.10",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-markdown": "^10.1.0",
        "tailwindcss": "^4.1.17",
        "typescript": "^5.9.3"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/node": "^22",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "concurrently": "^9.2.1",
        "cors-anywhere": "^0.4.4",
        "dotenv": "^17.3.1",
        "eslint": "^9",
        "eslint-config-next": "^16",
        "imapflow": "^1.2.13",
        "pino-pretty": "^13.1.3",
        "playwright": "^1.58.2",
        "tap": "^21.5.0",
        "turbo": "^2.8.0",
        "why-is-node-running": "^3.2.2"
    }
}
